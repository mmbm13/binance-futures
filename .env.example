# Copy to .env and fill in secrets. Never commit .env.

# ─── Server / DB ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/binance-bot-2
PORT=3001
LOG_LEVEL=info
# Optional: protect /logs endpoints when bot is exposed on a server (Bearer token or ?token=)
API_KEY=your-secret-token-here

# ─── Binance API ─────────────────────────────────────────────────────────────
USE_TESTNET=false
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── Symbol & leverage ───────────────────────────────────────────────────────
SYMBOL=ETHUSDT
LEVERAGE=10

# ─── Order book collection ───────────────────────────────────────────────────
ORDERBOOK_COLLECT_MINUTES=10
ORDERBOOK_BUCKET_SIZE=10
WALLS_TO_KEEP=10
BOOK_TICKER_STALE_MS=10000

# ─── Ladder ──────────────────────────────────────────────────────────────────
# Ladder levels (each rung must meet exchange min qty + notional after risk sizing)
LADDER_LEVELS=3
LADDER_SIZE_MULT=1.5
NOTIONAL_MULTIPLIER=1.4
# Min/max spacing between rungs (fraction, e.g. 0.01 = 1%)
MIN_LADDER_SPACING_PCT=0.01
MAX_LADDER_SPACING_PCT=0.02
# Min ticks between deepest ladder rung and building SL (prevents SL on same price as last order)
MIN_SL_GAP_TICKS=30

# ─── Risk & exits (BUILDING) ─────────────────────────────────────────────────
# Max loss per cycle as fraction of account balance (0.01 = 1%)
ACCOUNT_RISK_PERCENT=0.01
# TP reward vs risk in $ when qty is large enough (1.5 = 1.5× riskAmount)
TP_REWARD_RATIO=1.5
# Cap BUILDING TP distance from entry when qty is small (0.015 = 1.5%)
BUILDING_TP_MAX_PCT=0.015

# ─── Exits (HARVESTING, post-partial) ────────────────────────────────────────
# TP distance from entry in harvest; also fallback SL % when breakeven is breached (0.015 = 1.5%)
HARVEST_EXIT_PCT=0.015
# Optional overrides (default to HARVEST_EXIT_PCT)
# HARVEST_TP_MAX_PCT=0.015
# HARVEST_SL_MAX_PCT=0.015
# Harvest SL floor: breakeven ± buffer to cover round-trip fees (0.001 = 0.1%)
HARVEST_BREAKEVEN_BUFFER_PCT=0.001
# Trailing SL distance from the best price since harvest began (0.0075 = 0.75%)
HARVEST_TRAIL_PCT=0.0075
# Re-place trailing SL only when it improves by at least this fraction of entry
HARVEST_TRAIL_MIN_STEP_PCT=0.001

# ─── Catastrophic backstop SL ────────────────────────────────────────────────
# When the normal SL is skipped (deferred/infeasible/near-trigger), a wide STOP_MARKET
# is always kept on the exchange at riskAmount × this multiple
CATASTROPHIC_SL_MULT=2.0

# ─── Partial close ───────────────────────────────────────────────────────────
# Min net profit = max(floor, riskAmount × ratio) before partial close
MIN_PARTIAL_PROFIT_RATIO=0.15
MIN_PARTIAL_PROFIT_FLOOR=0.05

# ─── Fees (Binance USDM defaults) ────────────────────────────────────────────
MAKER_FEE=0.0002
TAKER_FEE=0.0005
