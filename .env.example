# ─── BASE COMPARTIDA ─────────────────────────────────────────────────────────
# Copia a .env y completa los secretos. Nunca commitear .env.
#
# Configuración por capas (mayor prioridad gana):
#   1. Variables de entorno reales (CLI: STRATEGY=momentum PORT=3002 npm start)
#   2. .env.<estrategia>  (overlay por bot: .env.ladder, .env.momentum, ...)
#   3. .env               (este archivo: secretos e infraestructura compartida)
#
# Los parámetros específicos de cada estrategia viven en su overlay:
#   .env.ladder.example, .env.momentum.example

# ─── Server / DB ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/binance-bot-2
PORT=3001
LOG_LEVEL=info
# Protege /logs cuando el bot está expuesto (Bearer token o ?token=)
API_KEY=your-secret-token-here

# ─── Binance API ─────────────────────────────────────────────────────────────
USE_TESTNET=false
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ─── Estrategia activa ───────────────────────────────────────────────────────
# ladder | funding | momentum | liqrev | bounce
STRATEGY=ladder
# live = órdenes reales; paper = fills simulados contra bookTicker (no soportado en ladder)
EXECUTION_MODE=live

# ─── Símbolo & leverage ──────────────────────────────────────────────────────
SYMBOL=ETHUSDT
LEVERAGE=10

# ─── Fees (Binance USDM por defecto) ─────────────────────────────────────────
MAKER_FEE=0.0002
TAKER_FEE=0.0005

# ─── Paper trading ───────────────────────────────────────────────────────────
PAPER_INITIAL_BALANCE=1000
PAPER_SLIPPAGE_PCT=0.0002

# ─── Comparación de estrategias ──────────────────────────────────────────────
# Intervalo de snapshots de equity para /compare (minutos)
EQUITY_SNAPSHOT_MINUTES=60
