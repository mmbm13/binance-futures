# Overlay para STRATEGY=bounce — copiar a .env.bounce
PORT=3003
EXECUTION_MODE=paper

# ─── Recolección de zonas ────────────────────────────────────────────────────
BOUNCE_COLLECT_MINUTES=10
BOUNCE_SAMPLE_INTERVAL_SEC=10
BOUNCE_BUCKET_SIZE=10
BOUNCE_WALLS_TO_KEEP=10
BOUNCE_MAX_ZONES_PER_SIDE=3
BOUNCE_WALL_PRESENCE=0.7
BOUNCE_WALL_MIN_RATIO=3
BOUNCE_ZONE_RETENTION=0.5

# ─── Señal de rebote ────────────────────────────────────────────────────────
BOUNCE_ZONE_TOUCH_PCT=0.001
BOUNCE_CONFIRM_REBOUND_PCT=0.0015
BOUNCE_CONFIRM_CVD=true

# ─── Riesgo & stops ──────────────────────────────────────────────────────────
BOUNCE_RISK_PCT=0.01
BOUNCE_ATR_PERIOD=14
BOUNCE_SL_ATR_BUFFER=0.5
BOUNCE_BREAKEVEN_TRIGGER_PCT=0.0075

# ─── Anti-martingala (agregar solo a favor) ──────────────────────────────────
BOUNCE_MAX_ADDS=2
BOUNCE_ADD_TRIGGER_R=0.5
BOUNCE_ADD_SIZE_RATIO=0.5
BOUNCE_SETUP_TTL_MIN=30
BOUNCE_LIMIT_FILL_SEC=10
