# Overlay para STRATEGY=momentum — copiar a .env.momentum
# Se aplica encima de .env (las variables CLI siguen ganando).

PORT=3002
# Empezar SIEMPRE en paper; pasar a live solo tras superar los criterios de /compare
EXECUTION_MODE=paper

# ─── Señal (breakout Donchian) ───────────────────────────────────────────────
MOM_INTERVAL=1h
MOM_DONCHIAN_PERIOD=20
MOM_ATR_PERIOD=14
MOM_ADX_PERIOD=14

# ─── Stops ───────────────────────────────────────────────────────────────────
# Stop inicial = 2×ATR; trailing chandelier = 3×ATR desde el extremo favorable
MOM_ATR_STOP_MULT=2.0
MOM_ATR_TRAIL_MULT=3.0

# ─── Filtros ─────────────────────────────────────────────────────────────────
# No operar sin tendencia (ADX mínimo) ni velas de ruptura gigantes (>4×ATR)
MOM_ADX_MIN=20
MOM_MAX_BREAKOUT_ATR=4
# Veto de funding: no long si APR > 0.30, no short si APR < −0.30
MOM_FUNDING_VETO_APR=0.30

# ─── Riesgo ──────────────────────────────────────────────────────────────────
MOM_RISK_PCT=0.01
# Circuit breaker: pausa tras N pérdidas consecutivas
MOM_MAX_CONSECUTIVE_LOSSES=6
MOM_PAUSE_HOURS=24
