# Overlay para STRATEGY=ladder — copiar a .env.ladder
# Se aplica encima de .env (las variables CLI siguen ganando).

PORT=3001
EXECUTION_MODE=live

# ─── Recolección de order book ───────────────────────────────────────────────
ORDERBOOK_COLLECT_MINUTES=10
ORDERBOOK_BUCKET_SIZE=10
WALLS_TO_KEEP=10
BOOK_TICKER_STALE_MS=10000

# ─── Escalera ────────────────────────────────────────────────────────────────
# Niveles (cada peldaño debe cumplir minQty + minNotional tras el risk sizing)
LADDER_LEVELS=3
LADDER_SIZE_MULT=1.5
NOTIONAL_MULTIPLIER=1.4
# Espaciado min/max entre peldaños (fracción: 0.01 = 1%)
MIN_LADDER_SPACING_PCT=0.01
MAX_LADDER_SPACING_PCT=0.02
# Ticks mínimos entre el peldaño más profundo y el SL de building
MIN_SL_GAP_TICKS=30

# ─── Riesgo & exits (BUILDING) ───────────────────────────────────────────────
# Pérdida máxima por ciclo como fracción del balance (0.01 = 1%)
ACCOUNT_RISK_PERCENT=0.01
# TP en $ vs riesgo cuando el qty alcanza (1.5 = 1.5× riskAmount)
TP_REWARD_RATIO=1.5
# Tope de distancia del TP en BUILDING cuando el qty es chico (0.015 = 1.5%)
BUILDING_TP_MAX_PCT=0.015
# Trailing en BUILDING tras el 1er fill (sustituye TP fijo al alcanzar activation %)
BUILDING_TRAIL_ENABLED=true
# Umbral favorable que activa el trail (default = BUILDING_TP_MAX_PCT)
# BUILDING_TRAIL_ACTIVATION_PCT=0.015
# Piso mínimo de ganancia del SL trailing (default = activation)
# BUILDING_TRAIL_FLOOR_PCT=0.015
# Distancia del trailing desde el mejor precio (default = HARVEST_TRAIL_PCT)
# BUILDING_TRAIL_PCT=0.0075
# Re-colocar trailing solo si mejora al menos esta fracción de la entrada
# BUILDING_TRAIL_MIN_STEP_PCT=0.001

# ─── Exits (HARVESTING, post-parcial) ────────────────────────────────────────
# Distancia del TP en harvest; también SL simétrico de fallback (0.015 = 1.5%)
HARVEST_EXIT_PCT=0.015
# Overrides opcionales (default: HARVEST_EXIT_PCT)
# HARVEST_TP_MAX_PCT=0.015
# HARVEST_SL_MAX_PCT=0.015
# Piso del SL de harvest: breakeven ± buffer para cubrir fees (0.001 = 0.1%)
HARVEST_BREAKEVEN_BUFFER_PCT=0.001
# Distancia del trailing desde el mejor precio del harvest (0.0075 = 0.75%)
HARVEST_TRAIL_PCT=0.0075
# Re-colocar el trailing solo si mejora al menos esta fracción de la entrada
HARVEST_TRAIL_MIN_STEP_PCT=0.001

# ─── SL catastrófico de respaldo ─────────────────────────────────────────────
# STOP_MARKET amplio siempre presente cuando el SL normal se omite
CATASTROPHIC_SL_MULT=2.0

# ─── Cierre parcial ──────────────────────────────────────────────────────────
# Ganancia neta mínima = max(floor, riskAmount × ratio) antes del parcial
MIN_PARTIAL_PROFIT_RATIO=0.15
MIN_PARTIAL_PROFIT_FLOOR=0.05
