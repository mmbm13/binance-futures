# Overlay para STRATEGY=liqrev — copiar a .env.liqrev
PORT=3004
EXECUTION_MODE=paper

# ─── Detección de cascada ───────────────────────────────────────────────────
LIQREV_WINDOW_SEC=60
LIQREV_PERCENTILE=0.99
LIQREV_MIN_NOTIONAL=500000
LIQREV_PRICE_MOVE_ATR=3
LIQREV_EXHAUST_SEC=45
LIQREV_ARMED_TTL_MIN=10

# ─── Riesgo & salidas ───────────────────────────────────────────────────────
LIQREV_RISK_PCT=0.01
LIQREV_ATR_PERIOD=14
LIQREV_SL_BUFFER_ATR=0.5
LIQREV_TP_RETRACE=0.5
LIQREV_TIME_STOP_MIN=45
LIQREV_COOLDOWN_MIN=30

# Paper / testnet: bajar LIQREV_MIN_NOTIONAL si no hay cascadas reales
# LIQREV_MIN_NOTIONAL=50000
